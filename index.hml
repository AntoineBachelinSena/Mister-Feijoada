<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Buffet Mister Feijoada • Feijoada a Domicílio São Paulo</title>
    <meta name="description" content="Feijoada saborosa é com Mister Feijoada! Levamos estrutura completa e preparamos tudo com muito carinho desde 2012.">

    <!-- FAVICON -->
    <link rel="icon" href="images/favicon.ico" type="image/x-icon">

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&amp;family=Inter:wght@400;500;600&amp;display=swap');
        
        body { font-family: 'Inter', system_ui, sans-serif; }
        .heading-serif { font-family: 'Playfair Display', Georgia, serif; }

        .hero-bg {
            background: linear-gradient(rgba(30, 25, 22, 0.72), rgba(30, 25, 22, 0.65)), 
                        url('images/buffet-completo-1.jpg');
            background-size: cover;
            background-position: center;
        }

        .scarcity-box {
            background: linear-gradient(135deg, #6B2E22, #8B3A2E);
            box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.2);
        }

        .food-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .food-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1);
        }

        .whatsapp-float {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
        }
    </style>
</head>
<body class="bg-[#FDF8F3] text-[#2D3748]">

    <!-- NAV -->
    <nav class="bg-white border-b sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex justify-between items-center h-20">
                <div class="flex items-center gap-x-3">
                    <div class="w-11 h-11 bg-[#9C4221] rounded-full flex items-center justify-center">
                        <i class="fa-solid fa-utensils text-white text-2xl"></i>
                    </div>
                    <div>
                        <span class="font-bold text-2xl tracking-tight">Mister Feijoada</span>
                        <span class="block text-[10px] text-[#9C4221] -mt-1 font-medium">DESDE 2012</span>
                    </div>
                </div>

                <div class="hidden md:flex items-center gap-x-8 text-sm font-medium">
                    <a href="#galeria" class="hover:text-[#9C4221]">Galeria</a>
                    <a href="#depoimentos" class="hover:text-[#9C4221]">Depoimentos</a>
                    <a href="#contato" class="hover:text-[#9C4221]">Contato</a>
                </div>

                <a href="https://wa.me/5511953756578?text=Olá!%20Gostaria%20de%20um%20orçamento%20rápido." 
                   target="_blank"
                   class="hidden md:flex items-center gap-x-2 bg-[#25D366] hover:bg-[#128C7E] text-white px-5 py-2.5 rounded-full text-sm font-semibold">
                    <i class="fa-brands fa-whatsapp text-lg"></i>
                    <span>WhatsApp</span>
                </a>
            </div>
        </div>
    </nav>

    <!-- HERO MELHORADO -->
    <header class="hero-bg h-[100dvh] min-h-[640px] flex items-center relative">
        <div class="max-w-5xl mx-auto px-6">
            <div class="max-w-3xl">
                
                <!-- Texto principal com fundo escuro para legibilidade -->
                <div class="bg-[#1E1916]/75 backdrop-blur-md p-8 md:p-10 rounded-3xl mb-8">
                    <h1 class="text-white text-6xl md:text-7xl font-bold leading-[1.05] tracking-tighter heading-serif">
                        Feijoada saborosa<br>
                        é com <span class="text-[#D4A017]">Mister Feijoada !</span>
                    </h1>
                </div>

                <p class="text-white text-2xl md:text-3xl mb-8 max-w-lg drop-shadow">
                    Levamos toda estrutura, equipe especializada<br>e preparamos tudo com muito carinho.
                </p>

                <div class="flex flex-col sm:flex-row gap-4">
                    <a href="#contato" 
                       class="inline-flex items-center justify-center bg-[#9C4221] hover:bg-[#7A331A] transition text-white text-lg font-semibold px-10 py-4 rounded-2xl">
                        Solicitar Orçamento
                    </a>
                    
                    <a href="https://wa.me/5511953756578?text=Olá!%20Gostaria%20de%20um%20orçamento%20rápido." 
                       target="_blank"
                       class="inline-flex items-center justify-center gap-x-3 border-2 border-white/80 hover:bg-white/10 text-white text-lg font-semibold px-8 py-4 rounded-2xl">
                        <i class="fa-brands fa-whatsapp text-2xl"></i>
                        <span>Falar no WhatsApp</span>
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- SCARCITY BANNER (MAIS IMPACTANTE) -->
    <div class="max-w-5xl mx-auto px-6 -mt-6 relative z-10">
        <div class="scarcity-box text-white rounded-3xl p-8 md:p-10 text-center shadow-2xl">
            <div class="flex justify-center mb-3">
                <div class="inline-flex items-center gap-x-2 bg-white/20 px-4 py-1 rounded-full text-sm font-medium">
                    <i class="fa-solid fa-clock"></i>
                    <span>VAGAS LIMITADAS</span>
                </div>
            </div>
            
            <h3 class="text-3xl md:text-4xl font-bold leading-tight mb-2">
                Limitamos o número de eventos<br>por final de semana para manter a excelência.
            </h3>
            <p class="text-2xl font-semibold text-[#F4D9B8]">Reserve com antecedência.</p>
        </div>
    </div>

    <!-- BARRA DE CONFIANÇA -->
    <div class="bg-white border-b mt-10">
        <div class="max-w-6xl mx-auto px-6 py-6">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-y-4 text-center">
                <div><div class="font-bold text-3xl text-[#9C4221]">+ de 12 anos</div><div class="text-sm">de excelência</div></div>
                <div><div class="font-bold text-3xl text-[#9C4221]">Equipe própria</div><div class="text-sm">atenciosa e experiente</div></div>
                <div><div class="font-bold text-3xl text-[#9C4221]">Material completo</div><div class="text-sm">réchauds, pratos, talheres</div></div>
                <div><div class="font-bold text-3xl text-[#9C4221]">Preparo com carinho</div><div class="text-sm">ingredientes selecionados</div></div>
            </div>
        </div>
    </div>

    <!-- GALERIA -->
    <section id="galeria" class="max-w-7xl mx-auto px-6 py-14">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-8">
            <div>
                <span class="text-[#9C4221] font-semibold tracking-widest text-sm">FOTOS REAIS DOS NOSSOS EVENTOS</span>
                <h2 class="text-4xl md:text-5xl font-bold heading-serif mt-1">Veja como fica na prática</h2>
            </div>
            <a href="https://www.instagram.com/buffetmisterfeijoada/" target="_blank" 
               class="mt-4 md:mt-0 text-[#9C4221] font-semibold flex items-center gap-x-2 hover:underline">
                Ver mais no Instagram <i class="fa-solid fa-arrow-up-right-from-square"></i>
            </a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            <img src="images/buffet-completo-1.jpg" class="rounded-2xl aspect-[4/3] object-cover food-card w-full" alt="Buffet completo Mister Feijoada">
            <img src="images/feijoada-close-1.jpg" class="rounded-2xl aspect-[4/3] object-cover food-card w-full" alt="Feijoada na panela de barro">
            <img src="images/torresmo-close.jpg" class="rounded-2xl aspect-[4/3] object-cover food-card w-full" alt="Torresmo crocante">
            <img src="images/arroz-farofa.jpg" class="rounded-2xl aspect-[4/3] object-cover food-card w-full" alt="Arroz e farofa">
            <img src="images/salada-laranja.jpg" class="rounded-2xl aspect-[4/3] object-cover food-card w-full" alt="Salada e laranja">
            <img src="images/panela-feijoada-2.jpg" class="rounded-2xl aspect-[4/3] object-cover food-card w-full" alt="Panela de feijoada">
            <img src="images/laranja-close.jpg" class="rounded-2xl aspect-square object-cover food-card w-full" alt="Laranja fatiada">
            <img src="images/farofa-close.jpg" class="rounded-2xl aspect-square object-cover food-card w-full" alt="Farofa caseira">
        </div>
    </section>

    <!-- DEPOIMENTOS -->
    <section id="depoimentos" class="bg-white py-14">
        <div class="max-w-6xl mx-auto px-6">
            <div class="text-center mb-10">
                <span class="text-[#9C4221] font-semibold tracking-widest text-sm">O QUE NOSSOS CLIENTES DIZEM</span>
                <h2 class="text-4xl md:text-5xl font-bold heading-serif mt-2">Avaliações reais</h2>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="bg-[#FDF8F3] p-7 rounded-3xl">
                    <div class="flex text-[#D4A017] mb-3"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                    <p class="italic">"A feijoada estava incrível, bem temperada e com carnes de qualidade. A equipe foi super atenciosa e profissional. Meus convidados amaram!"</p>
                    <div class="mt-5 text-sm"><strong>— Ana Paula Mendes</strong><br><span class="text-xs text-gray-500">Aniversário • Butantã • 5 estrelas</span></div>
                </div>

                <div class="bg-[#FDF8F3] p-7 rounded-3xl">
                    <div class="flex text-[#D4A017] mb-3"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                    <p class="italic">"Contratamos para um evento corporativo e superou todas as expectativas. Tudo muito organizado, comida deliciosa e serviço impecável."</p>
                    <div class="mt-5 text-sm"><strong>— Carlos Eduardo Silva</strong><br><span class="text-xs text-gray-500">Evento corporativo • Vila Olímpia • 5 estrelas</span></div>
                </div>

                <div class="bg-[#FDF8F3] p-7 rounded-3xl">
                    <div class="flex text-[#D4A017] mb-3"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                    <p class="italic">"Perfeito para a festa de aniversário. A feijoada estava saborosa, o torresmo crocante e a apresentação linda. Recomendo muito!"</p>
                    <div class="mt-5 text-sm"><strong>— Juliana Costa</strong><br><span class="text-xs text-gray-500">Aniversário • Osasco • 5 estrelas</span></div>
                </div>

                <div class="bg-[#FDF8F3] p-7 rounded-3xl">
                    <div class="flex text-[#D4A017] mb-3"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                    <p class="italic">"Melhor feijoada a domicílio que já experimentei em São Paulo. Atendimento nota 10 e qualidade dos ingredientes. Recomendo de olhos fechados!"</p>
                    <div class="mt-5 text-sm"><strong>— Roberto Almeida</strong><br><span class="text-xs text-gray-500">Festa em casa • Lapa • 5 estrelas</span></div>
                </div>
            </div>
        </div>
    </section>

    <!-- CONTATO -->
    <section id="contato" class="bg-[#2D3748] text-white py-16">
        <div class="max-w-3xl mx-auto px-6 text-center">
            <h2 class="text-4xl md:text-5xl font-bold heading-serif mb-4">Reserve seu evento</h2>
            <p class="text-xl text-white/80 mb-8">Resposta rápida via WhatsApp</p>

            <a href="https://wa.me/5511953756578?text=Olá!%20Gostaria%20de%20um%20orçamento%20rápido%20para%20meu%20evento." 
               target="_blank"
               class="inline-flex items-center justify-center gap-x-4 bg-[#25D366] hover:bg-[#128C7E] transition-all text-white text-xl font-bold px-14 py-5 rounded-2xl shadow-xl">
                <i class="fa-brands fa-whatsapp text-3xl"></i>
                <span>Falar no WhatsApp agora</span>
            </a>

            <p class="mt-6 text-sm text-white/60">Limitamos o número de eventos por final de semana para manter a excelência.<br>Reserve com antecedência.</p>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-[#1A202C] text-white/70 py-10 text-sm">
        <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-y-8">
            <div>
                <div class="flex items-center gap-x-3 mb-4">
                    <div class="w-9 h-9 bg-[#9C4221] rounded-full flex items-center justify-center">
                        <i class="fa-solid fa-utensils text-white"></i>
                    </div>
                    <span class="font-bold text-white text-xl">Buffet Mister Feijoada</span>
                </div>
                <p>Desde 2012 preparando feijoadas com carinho em São Paulo e região.</p>
            </div>
            
            <div class="md:text-right space-y-1">
                <div><strong class="text-white">WhatsApp:</strong> (11) 95375-6578</div>
                <div><strong class="text-white">E-mail:</strong> contato@mrfeijoada.com.br</div>
                <div class="pt-2"><a href="https://www.instagram.com/buffetmisterfeijoada/" target="_blank" class="hover:text-white">@buffetmisterfeijoada</a></div>
            </div>
        </div>
        <div class="text-center text-xs mt-10 text-white/40">© 2026 Buffet Mister Feijoada. Feito com carinho para seus eventos.</div>
    </footer>

    <!-- FLOATING WHATSAPP -->
    <a href="https://wa.me/5511953756578?text=Olá!%20Gostaria%20de%20um%20orçamento%20rápido." 
       target="_blank"
       class="whatsapp-float flex items-center gap-x-3 bg-[#25D366] hover:bg-[#128C7E] text-white px-6 py-3.5 rounded-full shadow-xl text-sm font-semibold">
        <i class="fa-brands fa-whatsapp text-3xl"></i>
        <div class="leading-tight">
            <div class="font-bold">Orçamento Rápido</div>
            <div class="text-[10px] -mt-0.5">Resposta em menos de 3 minutos</div>
        </div>
    </a>

    <script>
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    e.preventDefault();
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });
    </script>
</body>
</html>
