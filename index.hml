<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Buffet Mister Feijoada • Feijoada a Domicílio em São Paulo</title>
    <meta name="description" content="Feijoada saborosa é com Mister Feijoada! Levamos toda estrutura, equipe especializada e preparamos tudo com muito carinho desde 2012.">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&amp;family=Inter:wght@400;500;600&amp;display=swap');
        
        body { font-family: 'Inter', system_ui, sans-serif; }
        .heading-serif { font-family: 'Playfair Display', Georgia, serif; }

        .hero-bg {
            background: linear-gradient(rgba(0,0,0,0.50), rgba(0,0,0,0.40)), url('images/buffet-completo-1.jpg');
            background-size: cover;
            background-position: center;
        }

        .food-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .food-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1);
        }

        .scarcity-banner {
            background: linear-gradient(90deg, #9C4221, #B85C3A);
        }

        .whatsapp-float {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
            box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.3);
        }
    </style>
</head>
<body class="bg-[#FDF8F3] text-[#2D3748]">

    <!-- NAV -->
    <nav class="bg-white border-b sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex justify-between items-center h-20">
                <div class="flex items-center gap-x-3">
                    <div class="w-11 h-11 bg-[#9C4221] rounded-full flex items-center justify-center">
                        <i class="fa-solid fa-utensils text-white text-2xl"></i>
                    </div>
                    <div>
                        <span class="font-bold text-2xl tracking-tight">Mister Feijoada</span>
                        <span class="block text-[10px] text-[#9C4221] -mt-1 font-medium">DESDE 2012</span>
                    </div>
                </div>

                <div class="hidden md:flex items-center gap-x-8 text-sm font-medium">
                    <a href="#diferenciais" class="hover:text-[#9C4221]">Diferenciais</a>
                    <a href="#como-funciona" class="hover:text-[#9C4221]">Como Funciona</a>
                    <a href="#galeria" class="hover:text-[#9C4221]">Galeria</a>
                    <a href="#depoimentos" class="hover:text-[#9C4221]">Depoimentos</a>
                    <a href="#contato" class="hover:text-[#9C4221]">Contato</a>
                </div>

                <div class="flex items-center gap-x-4">
                    <a href="https://wa.me/5511953756578?text=Olá!%20Gostaria%20de%20um%20orçamento%20rápido." 
                       target="_blank"
                       class="hidden md:flex items-center gap-x-2 bg-[#25D366] hover:bg-[#128C7E] text-white px-5 py-2.5 rounded-full text-sm font-semibold">
                        <i class="fa-brands fa-whatsapp text-lg"></i>
                        <span>WhatsApp</span>
                    </a>
                    
                    <button id="mobile-menu-btn" class="md:hidden w-10 h-10 flex items-center justify-center text-2xl">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- HERO -->
    <header class="hero-bg h-[100dvh] min-h-[620px] flex items-center relative">
        <div class="max-w-5xl mx-auto px-6 text-white">
            <div class="max-w-3xl">
                <div class="inline-flex items-center gap-x-2 bg-white/20 backdrop-blur-md px-4 py-1 rounded-full mb-6 text-sm">
                    <div class="w-2 h-2 bg-[#D69E2E] rounded-full animate-pulse"></div>
                    <span class="font-medium">Atendendo São Paulo e Grande SP desde 2012</span>
                </div>
                
                <h1 class="text-6xl md:text-7xl font-bold leading-[1.05] tracking-tighter heading-serif mb-6">
                    Feijoada saborosa<br>é com Mister Feijoada !
                </h1>
                
                <p class="text-2xl md:text-3xl text-white/90 mb-8 max-w-lg">
                    Levamos toda estrutura, equipe especializada e preparamos tudo com muito carinho.
                </p>

                <div class="flex flex-col sm:flex-row gap-4">
                    <a href="#contato" class="inline-flex items-center justify-center gap-x-3 bg-[#9C4221] hover:bg-[#7A331A] transition-all text-white text-lg font-semibold px-9 py-4 rounded-2xl">
                        Solicitar Orçamento
                    </a>
                    
                    <a href="https://wa.me/5511953756578?text=Olá!%20Gostaria%20de%20um%20orçamento%20rápido." 
                       target="_blank"
                       class="inline-flex items-center justify-center gap-x-3 border-2 border-white/70 hover:bg-white/10 transition-all text-white text-lg font-semibold px-8 py-4 rounded-2xl">
                        <i class="fa-brands fa-whatsapp text-2xl"></i>
                        <span>Falar no WhatsApp agora</span>
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- SCARCITY BANNER (DESTAQUE FORTE) -->
    <div class="scarcity-banner text-white py-3.5">
        <div class="max-w-5xl mx-auto px-6 text-center">
            <p class="font-semibold text-lg">
                <i class="fa-solid fa-clock mr-2"></i> 
                Limitamos o número de eventos por final de semana para manter a excelência. 
                <span class="font-bold">Reserve com antecedência.</span>
            </p>
        </div>
    </div>

    <!-- BARRA DE CONFIANÇA -->
    <div class="bg-white border-b">
        <div class="max-w-6xl mx-auto px-6 py-5">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-y-4 text-center">
                <div><div class="font-bold text-3xl text-[#9C4221]">+ de 12 anos</div><div class="text-sm">de excelência</div></div>
                <div><div class="font-bold text-3xl text-[#9C4221]">Equipe própria</div><div class="text-sm">atenciosa e experiente</div></div>
                <div><div class="font-bold text-3xl text-[#9C4221]">Material completo</div><div class="text-sm">réchauds, pratos, talheres</div></div>
                <div><div class="font-bold text-3xl text-[#9C4221]">Preparo com carinho</div><div class="text-sm">ingredientes selecionados</div></div>
            </div>
        </div>
    </div>

    <!-- DIFERENCIAIS -->
    <section id="diferenciais" class="max-w-6xl mx-auto px-6 pt-14 pb-12">
        <div class="text-center mb-10">
            <span class="text-[#9C4221] font-semibold tracking-widest text-sm">POR QUE ESCOLHER O MISTER FEIJOADA</span>
            <h2 class="text-4xl md:text-5xl font-bold heading-serif mt-2">Não entregamos só comida.<br>Entregamos experiência.</h2>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
            <div class="bg-white p-8 rounded-3xl shadow">
                <div class="w-12 h-12 bg-[#FDF8F3] rounded-2xl flex items-center justify-center mb-6">
                    <i class="fa-solid fa-users text-[#9C4221] text-3xl"></i>
                </div>
                <h3 class="font-semibold text-xl mb-3">Equipe própria e atenciosa</h3>
                <p class="text-[#4A5568]">Profissionais treinados para servir com excelência e simpatia.</p>
            </div>
            <div class="bg-white p-8 rounded-3xl shadow">
                <div class="w-12 h-12 bg-[#FDF8F3] rounded-2xl flex items-center justify-center mb-6">
                    <i class="fa-solid fa-boxes text-[#9C4221] text-3xl"></i>
                </div>
                <h3 class="font-semibold text-xl mb-3">Material completo incluso</h3>
                <p class="text-[#4A5568]">Réchauds, travessas, pratos, talheres, copos e equipe para montar e desmontar.</p>
            </div>
            <div class="bg-white p-8 rounded-3xl shadow">
                <div class="w-12 h-12 bg-[#FDF8F3] rounded-2xl flex items-center justify-center mb-6">
                    <i class="fa-solid fa-heart text-[#9C4221] text-3xl"></i>
                </div>
                <h3 class="font-semibold text-xl mb-3">Preparo com muito carinho</h3>
                <p class="text-[#4A5568]">Carnes de primeira linha, temperos selecionados e tudo preparado no local.</p>
            </div>
        </div>
    </section>

    <!-- COMO FUNCIONA -->
    <section id="como-funciona" class="bg-white py-14">
        <div class="max-w-6xl mx-auto px-6">
            <div class="text-center mb-10">
                <span class="text-[#9C4221] font-semibold tracking-widest text-sm">PROCESSO SIMPLES</span>
                <h2 class="text-4xl md:text-5xl font-bold heading-serif mt-2">Como funciona na prática</h2>
            </div>

            <div class="grid md:grid-cols-3 lg:grid-cols-6 gap-6 text-center">
                <div><div class="mx-auto w-14 h-14 flex items-center justify-center text-3xl font-bold text-[#9C4221] mb-3">01</div><h4 class="font-semibold">Solicite o orçamento</h4></div>
                <div><div class="mx-auto w-14 h-14 flex items-center justify-center text-3xl font-bold text-[#9C4221] mb-3">02</div><h4 class="font-semibold">Escolha data e cardápio</h4></div>
                <div><div class="mx-auto w-14 h-14 flex items-center justify-center text-3xl font-bold text-[#9C4221] mb-3">03</div><h4 class="font-semibold">Levamos toda estrutura</h4></div>
                <div><div class="mx-auto w-14 h-14 flex items-center justify-center text-3xl font-bold text-[#9C4221] mb-3">04</div><h4 class="font-semibold">Preparamos no local</h4></div>
                <div><div class="mx-auto w-14 h-14 flex items-center justify-center text-3xl font-bold text-[#9C4221] mb-3">05</div><h4 class="font-semibold">Servimos seus convidados</h4></div>
                <div><div class="mx-auto w-14 h-14 flex items-center justify-center text-3xl font-bold text-[#9C4221] mb-3">06</div><h4 class="font-semibold">Deixamos tudo organizado</h4></div>
            </div>
        </div>
    </section>

    <!-- GALERIA COM NOVAS FOTOS -->
    <section id="galeria" class="max-w-7xl mx-auto px-6 py-14">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-8">
            <div>
                <span class="text-[#9C4221] font-semibold tracking-widest text-sm">FOTOS REAIS DOS NOSSOS EVENTOS</span>
                <h2 class="text-4xl md:text-5xl font-bold heading-serif mt-1">Veja como fica na prática</h2>
            </div>
            <a href="https://www.instagram.com/buffetmisterfeijoada/" target="_blank" class="mt-4 md:mt-0 text-[#9C4221] font-semibold flex items-center gap-x-2 hover:underline">
                Ver mais no Instagram <i class="fa-solid fa-arrow-up-right-from-square"></i>
            </a>
        </div>

        <!-- Fotos Profissionais / Buffet -->
        <div class="mb-10">
            <h3 class="font-semibold text-xl mb-4 flex items-center gap-x-2">
                <i class="fa-solid fa-camera text-[#9C4221]"></i> Fotos do Buffet
            </h3>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                <!-- Novas fotos (sem repetição) -->
                <img src="images/buffet-completo-1.jpg" class="rounded-2xl aspect-[4/3] object-cover food-card w-full" alt="Buffet completo Mister Feijoada">
                <img src="images/feijoada-close-1.jpg" class="rounded-2xl aspect-[4/3] object-cover food-card w-full" alt="Feijoada na panela de barro">
                <img src="images/torresmo-close.jpg" class="rounded-2xl aspect-[4/3] object-cover food-card w-full" alt="Torresmo crocante">
                <img src="images/arroz-farofa.jpg" class="rounded-2xl aspect-[4/3] object-cover food-card w-full" alt="Arroz e farofa">
                <img src="images/salada-laranja.jpg" class="rounded-2xl aspect-[4/3] object-cover food-card w-full" alt="Salada e laranja">
                <img src="images/panela-feijoada-2.jpg" class="rounded-2xl aspect-[4/3] object-cover food-card w-full" alt="Panela de feijoada fumegante">
            </div>
        </div>

        <!-- Detalhes e Acompanhamentos -->
        <div>
            <h3 class="font-semibold text-xl mb-4 flex items-center gap-x-2">
                <i class="fa-solid fa-utensils text-[#9C4221]"></i> Detalhes e Acompanhamentos
            </h3>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                <img src="images/laranja-close.jpg" class="rounded-2xl aspect-square object-cover food-card w-full" alt="Laranja fatiada">
                <img src="images/farofa-close.jpg" class="rounded-2xl aspect-square object-cover food-card w-full" alt="Farofa caseira">
                <img src="images/cartao-visita.jpg" class="rounded-2xl aspect-square object-cover food-card w-full" alt="Cartão Mister Feijoada">
                <img src="images/panela-feijoada-3.jpg" class="rounded-2xl aspect-square object-cover food-card w-full" alt="Feijoada pronta para servir">
            </div>
        </div>
    </section>

    <!-- DEPOIMENTOS -->
    <section id="depoimentos" class="bg-white py-14">
        <div class="max-w-6xl mx-auto px-6">
            <div class="text-center mb-10">
                <span class="text-[#9C4221] font-semibold tracking-widest text-sm">O QUE NOSSOS CLIENTES DIZEM</span>
                <h2 class="text-4xl md:text-5xl font-bold heading-serif mt-2">Experiências reais</h2>
            </div>

            <div class="grid md:grid-cols-3 gap-6">
                <div class="bg-[#FDF8F3] p-7 rounded-3xl">
                    <div class="flex text-[#D69E2E] mb-3"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                    <p class="italic">"A feijoada estava deliciosa e a equipe muito atenciosa. Meus convidados elogiaram bastante. Já quero repetir!"</p>
                    <div class="mt-5 text-sm"><strong>— Camila R.</strong> • Aniversário • Butantã</div>
                </div>
                <div class="bg-[#FDF8F3] p-7 rounded-3xl">
                    <div class="flex text-[#D69E2E] mb-3"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                    <p class="italic">"Contratamos para evento da empresa. Tudo perfeito, desde a montagem até a limpeza. Profissionalismo excelente."</p>
                    <div class="mt-5 text-sm"><strong>— Ricardo Mendes</strong> • Evento corporativo • Vila Olímpia</div>
                </div>
                <div class="bg-[#FDF8F3] p-7 rounded-3xl">
                    <div class="flex text-[#D69E2E] mb-3"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star-half-stroke"></i></div>
                    <p class="italic">"Superou todas as expectativas. A feijoada estava saborosa e o serviço impecável. Recomendo muito!"</p>
                    <div class="mt-5 text-sm"><strong>— Família Silva</strong> • Casamento • Osasco</div>
                </div>
            </div>
        </div>
    </section>

    <!-- CONTATO + FORMULÁRIO -->
    <section id="contato" class="bg-[#2D3748] text-white py-16">
        <div class="max-w-4xl mx-auto px-6">
            <div class="text-center mb-8">
                <h2 class="text-4xl md:text-5xl font-bold heading-serif">Reserve seu evento</h2>
                <p class="mt-3 text-lg text-white/70">Resposta em menos de 3 minutos</p>
            </div>

            <!-- Scarcity reforçado -->
            <div class="max-w-2xl mx-auto mb-8 bg-[#9C4221]/90 text-white text-center py-3 rounded-2xl text-sm font-semibold">
                Limitamos o número de eventos por final de semana para manter a excelência.<br>
                <span class="font-bold">Reserve com antecedência.</span>
            </div>

            <form id="orcamento-form" class="bg-white text-[#2D3748] rounded-3xl p-8 md:p-10 max-w-2xl mx-auto shadow-xl">
                <div class="grid md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-medium mb-1.5">Seu nome</label>
                        <input type="text" id="nome" required class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:border-[#9C4221]">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1.5">Data do evento</label>
                        <input type="date" id="data" required class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:border-[#9C4221]">
                    </div>
                </div>

                <div class="grid md:grid-cols-2 gap-5 mt-5">
                    <div>
                        <label class="block text-sm font-medium mb-1.5">Número de convidados</label>
                        <input type="number" id="convidados" required placeholder="Ex: 80" class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:border-[#9C4221]">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1.5">Tipo de evento</label>
                        <select id="tipo" required class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:border-[#9C4221]">
                            <option value="">Selecione...</option>
                            <option value="Aniversário">Aniversário</option>
                            <option value="Evento Corporativo">Evento Corporativo</option>
                            <option value="Casamento / Bodas">Casamento / Bodas</option>
                            <option value="Festa em casa / Condomínio">Festa em casa / Condomínio</option>
                            <option value="Outro">Outro</option>
                        </select>
                    </div>
                </div>

                <div class="mt-5">
                    <label class="block text-sm font-medium mb-1.5">Bairro / Cidade do evento</label>
                    <input type="text" id="local" required placeholder="Ex: Butantã, São Paulo" class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:border-[#9C4221]">
                </div>

                <button type="submit" class="mt-7 w-full bg-[#25D366] hover:bg-[#128C7E] text-white font-bold text-lg py-4 rounded-2xl flex items-center justify-center gap-x-3">
                    <i class="fa-brands fa-whatsapp text-2xl"></i>
                    <span>Enviar para WhatsApp e receber orçamento rápido</span>
                </button>
            </form>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-[#1A202C] text-white/70 py-10 text-sm">
        <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-y-8">
            <div>
                <div class="flex items-center gap-x-3 mb-4">
                    <div class="w-9 h-9 bg-[#9C4221] rounded-full flex items-center justify-center">
                        <i class="fa-solid fa-utensils text-white"></i>
                    </div>
                    <span class="font-bold text-white text-xl">Buffet Mister Feijoada</span>
                </div>
                <p>Desde 2012 preparando feijoadas com carinho em São Paulo e região.</p>
            </div>
            
            <div class="md:text-right space-y-1">
                <div><strong class="text-white">WhatsApp:</strong> (11) 95375-6578</div>
                <div><strong class="text-white">E-mail:</strong> contato@mrfeijoada.com.br</div>
                <div class="pt-2"><a href="https://www.instagram.com/buffetmisterfeijoada/" target="_blank" class="hover:text-white">@buffetmisterfeijoada</a></div>
            </div>
        </div>
        <div class="text-center text-xs mt-10 text-white/40">© 2026 Buffet Mister Feijoada. Feito com carinho para seus eventos.</div>
    </footer>

    <!-- FLOATING WHATSAPP -->
    <a href="https://wa.me/5511953756578?text=Olá!%20Gostaria%20de%20um%20orçamento%20rápido%20para%20meu%20evento." 
       target="_blank"
       class="whatsapp-float flex items-center gap-x-3 bg-[#25D366] hover:bg-[#128C7E] text-white px-6 py-3.5 rounded-full shadow-xl text-sm font-semibold">
        <i class="fa-brands fa-whatsapp text-3xl"></i>
        <div class="leading-tight">
            <div class="font-bold">Orçamento Rápido</div>
            <div class="text-[10px] -mt-0.5">Resposta em menos de 3 minutos</div>
        </div>
    </a>

    <script>
        // Mobile menu
        const mobileBtn = document.getElementById('mobile-menu-btn');
        if (mobileBtn) {
            mobileBtn.addEventListener('click', () => {
                const nav = document.createElement('div');
                nav.className = 'fixed inset-0 bg-black/90 z-[999] flex flex-col p-8 text-white text-2xl';
                nav.innerHTML = `
                    <div class="flex justify-end mb-8"><button class="text-4xl">×</button></div>
                    <a href="#diferenciais" class="py-4 border-b border-white/20">Diferenciais</a>
                    <a href="#como-funciona" class="py-4 border-b border-white/20">Como Funciona</a>
                    <a href="#galeria" class="py-4 border-b border-white/20">Galeria</a>
                    <a href="#depoimentos" class="py-4 border-b border-white/20">Depoimentos</a>
                    <a href="#contato" class="py-4">Contato / Orçamento</a>
                    <div class="mt-auto pt-8">
                        <a href="https://wa.me/5511953756578" target="_blank" class="flex items-center justify-center gap-x-3 bg-[#25D366] text-white py-4 rounded-2xl font-semibold">
                            <i class="fa-brands fa-whatsapp text-3xl"></i> <span>Abrir WhatsApp</span>
                        </a>
                    </div>`;
                document.body.appendChild(nav);
                nav.querySelector('button').onclick = () => nav.remove();
            });
        }

        // Form → WhatsApp
        const form = document.getElementById('orcamento-form');
        if (form) {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                const nome = document.getElementById('nome').value;
                const data = document.getElementById('data').value;
                const convidados = document.getElementById('convidados').value;
                const tipo = document.getElementById('tipo').value;
                const local = document.getElementById('local').value;

                const msg = `Olá! Gostaria de um orçamento rápido.%0A%0A*Nome:* ${nome}%0A*Data:* ${data}%0A*Convidados:* ${convidados}%0A*Tipo:* ${tipo}%0A*Local:* ${local}`;
                window.open(`https://wa.me/5511953756578?text=${msg}`, '_blank');
            });
        }

        // Smooth scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    e.preventDefault();
                    target.scrollIntoView({ behavior: 'smooth' });
                }
            });
        });
    </script>
</body>
</html>
